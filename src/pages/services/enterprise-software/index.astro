<!-- ═══════════════════════════════════════════
     8. PROCESS TIMELINE
═══════════════════════════════════════════ -->
<section class="hp-process-section" id="enterprise-process-section">
  <div class="hp-process-inner">
    <div class="hp-process-heading">
      <h2>From Vision to Victory: Our Proven Process</h2>
      <p>Discover how we turn your ideas into reality with our streamlined, client-focused development process. From initial consultation to final deployment, our expert team ensures every step is meticulously planned and executed to deliver outstanding results.</p>
    </div>
    <div class="hp-process-body">
      <div class="hp-process-steps" id="enterprise-process-steps">
        <div class="hp-process-line-track">
          <div class="hp-process-line-fill" id="enterprise-process-line-fill"></div>
        </div>
        <div class="hp-process-step" data-step="0">
          <div class="hp-step-dot-wrap"><div class="hp-step-dot"><i class="fa-solid fa-phone"></i></div></div>
          <div class="hp-step-content"><div class="hp-step-label">Step 1</div><div class="hp-step-card"><h4>Have a Conversation</h4><p>We want to hear your ideas, learn your company's workflow, and offer our software expertise to find a solution to your frustrations while facilitating your growth.</p></div></div>
        </div>
        <div class="hp-process-step" data-step="1">
          <div class="hp-step-dot-wrap"><div class="hp-step-dot"><i class="fa-solid fa-file-lines"></i></div></div>
          <div class="hp-step-content"><div class="hp-step-label">Step 2</div><div class="hp-step-card"><h4>Propose Solution</h4><p>Post conversation, we will send you a custom proposal with recommended technologies, a rough timeline, and a cost estimate to define the project specifications.</p></div></div>
        </div>
        <div class="hp-process-step" data-step="2">
          <div class="hp-step-dot-wrap"><div class="hp-step-dot"><i class="fa-solid fa-pen-ruler"></i></div></div>
          <div class="hp-step-content"><div class="hp-step-label">Step 3</div><div class="hp-step-card"><h4>Design</h4><p>Create lo-fi designs to outline basic structure, develop hi-fi designs for detailed visual representation, and build interactive prototypes for user testing and feedback.</p></div></div>
        </div>
        <div class="hp-process-step" data-step="3">
          <div class="hp-step-dot-wrap"><div class="hp-step-dot"><i class="fa-solid fa-code"></i></div></div>
          <div class="hp-step-content"><div class="hp-step-label">Step 4</div><div class="hp-step-card"><h4>Develop, Test, and Deploy</h4><p>Utilizing agile methodologies with iterative development cycles, continuous integration and testing, regular feedback sessions, and seamless deployment practices.</p></div></div>
        </div>
        <div class="hp-process-step" data-step="4">
          <div class="hp-step-dot-wrap"><div class="hp-step-dot"><i class="fa-solid fa-rocket"></i></div></div>
          <div class="hp-step-content"><div class="hp-step-label">Step 5</div><div class="hp-step-card"><h4>Post-Launch</h4><p>We stand by our work. After project completion, we warranty our work and remain available for future maintenance &amp; optimizations.</p></div></div>
        </div>
      </div>
      <div class="hp-process-right">
        <div class="hp-process-right-actions">
          <span class="hp-btn-back-arrow" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="1em" height="1em"><path d="M23 12H5M12 19l-7-7 7-7"/></svg>
          </span>
          <a href="/contact-us/" class="btn-orange">Get Started Today</a>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
(function () {
  const stepsContainer = document.getElementById('enterprise-process-steps');
  const lineFill = document.getElementById('enterprise-process-line-fill');
  const steps = Array.from(document.querySelectorAll('#enterprise-process-steps .hp-process-step'));
  if (!stepsContainer || !lineFill || !steps.length) return;
  function update() {
    const r = stepsContainer.getBoundingClientRect();
    const scrolled = Math.max(0, Math.min(1, (window.innerHeight * 0.6 - r.top) / r.height));
    lineFill.style.height = (scrolled * 100) + '%';
    steps.forEach(step => {
      const m = step.getBoundingClientRect();
      if (m.top + m.height / 2 < window.innerHeight * 0.65) step.classList.add('active');
      else step.classList.remove('active');
    });
  }
  window.addEventListener('scroll', update, { passive: true });
  update();
})();
</script>

